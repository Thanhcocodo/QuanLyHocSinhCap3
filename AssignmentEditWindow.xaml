<Window x:Class="QuanLyHocSinh.AssignmentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm Phân công" Height="340" Width="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Lớp *" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="LopCombo" Grid.Column="1" Height="32" Margin="0,0,0,8"
                  DisplayMemberPath="Display" SelectedValuePath="LopId"/>

        <TextBlock Text="Môn học *" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="MonHocCombo" Grid.Row="1" Grid.Column="1" Height="32" Margin="0,0,0,8"
                  DisplayMemberPath="Display" SelectedValuePath="MonHocId"/>

        <TextBlock Text="Giáo viên *" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="GiaoVienCombo" Grid.Row="2" Grid.Column="1" Height="32" Margin="0,0,0,8"
                  DisplayMemberPath="Display" SelectedValuePath="GiaoVienId"/>

        <TextBlock Text="Năm học *" Grid.Row="3" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <TextBox x:Name="NamHocBox" Grid.Row="3" Grid.Column="1" Height="32" Padding="6,4" Margin="0,0,0,8"/>

        <TextBlock Text="Học kỳ *" Grid.Row="4" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <ComboBox x:Name="HocKyCombo" Grid.Row="4" Grid.Column="1" Height="32" Margin="0,0,0,8">
            <ComboBoxItem Content="1" IsSelected="True"/>
            <ComboBoxItem Content="2"/>
        </ComboBox>

        <TextBlock Text="Chủ nhiệm" Grid.Row="5" VerticalAlignment="Center" Margin="0,0,8,8"/>
        <CheckBox x:Name="ChuNhiemCheck" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,8"/>

        <TextBlock x:Name="ErrorText" Grid.Row="6" Grid.ColumnSpan="2"
                   Foreground="Red" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Hủy" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Lưu" Width="100" Background="#1a237e" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
