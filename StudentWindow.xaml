<Window x:Class="QuanLyHocSinh.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Học sinh" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1565c0">
            <DockPanel Margin="16,0">
                <TextBlock Text="🏫 Bảng điểm học sinh" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔑 Đổi mật khẩu" Height="30" Padding="12,0" Margin="0,0,6,0"
                            Background="#1976d2" Foreground="White" Click="ChangePassword_Click"/>
                    <Button Content="Đăng xuất" Height="30" Padding="12,0"
                            Background="#c62828" Foreground="White" Click="Logout_Click"/>
                    <TextBlock x:Name="InfoText" Foreground="#bbdefb" VerticalAlignment="Center" Margin="16,0,0,0" TextAlignment="Right"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Thông tin cá nhân -->
            <Border Grid.Row="0" Background="#e3f2fd" CornerRadius="8" Padding="16,10" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="HoTenText" FontWeight="Bold" FontSize="15" Margin="0,0,24,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LopText" Foreground="#555" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <TextBlock x:Name="NgaySinhText" Foreground="#555" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <TextBlock x:Name="TrangThaiText" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Filter -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Năm học:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="NamHocCombo" Width="140" Height="30" Margin="0,0,12,0"/>
                <TextBlock Text="Học kỳ:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="HocKyCombo" Width="100" Height="30" Margin="0,0,12,0">
                    <ComboBoxItem Content="Tất cả" IsSelected="True"/>
                    <ComboBoxItem Content="Học kỳ 1"/>
                    <ComboBoxItem Content="Học kỳ 2"/>
                </ComboBox>
                <Button Content="🔄 Xem điểm" Height="30" Padding="12,0"
                        Background="#1565c0" Foreground="White" Click="LoadGrades_Click"/>
            </StackPanel>

            <!-- Bảng điểm -->
            <DataGrid x:Name="GradeGrid" Grid.Row="2" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserAddRows="False"
                      AlternatingRowBackground="#f5f5f5" GridLinesVisibility="Horizontal"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Năm học" Binding="{Binding NamHoc}" Width="90"/>
                    <DataGridTextColumn Header="HK" Binding="{Binding HocKy}" Width="45"/>
                    <DataGridTextColumn Header="Môn học" Binding="{Binding TenMon}" Width="160"/>
                    <DataGridTextColumn Header="Miệng" Binding="{Binding DiemMieng, StringFormat=N1}" Width="65"/>
                    <DataGridTextColumn Header="15 phút" Binding="{Binding Diem15Phut, StringFormat=N1}" Width="65"/>
                    <DataGridTextColumn Header="1 tiết" Binding="{Binding Diem1Tiet, StringFormat=N1}" Width="65"/>
                    <DataGridTextColumn Header="Giữa kỳ" Binding="{Binding DiemGiuaKy, StringFormat=N1}" Width="70"/>
                    <DataGridTextColumn Header="Cuối kỳ" Binding="{Binding DiemCuoiKy, StringFormat=N1}" Width="70"/>
                    <DataGridTextColumn Header="TB môn" Binding="{Binding TBMon, StringFormat=N2}" Width="75">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DatYeuCau}" Value="False">
                                        <Setter Property="Foreground" Value="#c62828"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DatYeuCau}" Value="True">
                                        <Setter Property="Foreground" Value="#2e7d32"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Kết quả" Binding="{Binding KetQua}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Summary -->
            <Border Grid.Row="3" Background="#f9fbe7" CornerRadius="6" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="SummaryText" Foreground="#555"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
