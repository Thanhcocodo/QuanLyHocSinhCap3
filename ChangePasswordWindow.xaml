<Window x:Class="QuanLyHocSinh.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đổi mật khẩu" Height="375" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="24" Padding="0">
        <StackPanel>
            <TextBlock Text="Đổi mật khẩu" FontSize="16" FontWeight="Bold"
                       Foreground="#1a237e" Margin="0,0,0,16"/>

            <!-- Mật khẩu cũ -->
            <TextBlock Text="Mật khẩu cũ" Foreground="#555" Margin="0,0,0,4"/>
            <Grid Height="34" Margin="0,0,0,12">
                <PasswordBox x:Name="OldPassword" Padding="8,4"
                             BorderBrush="#bbb" BorderThickness="1" VerticalContentAlignment="Center"/>
                <TextBox x:Name="OldPasswordPlain" Padding="8,4"
                         BorderBrush="#bbb" BorderThickness="1" Visibility="Collapsed"
                         VerticalContentAlignment="Center"/>
                <ToggleButton x:Name="ShowOld" Content="👁" Width="30" HorizontalAlignment="Right"
                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                              Checked="ShowOld_Checked" Unchecked="ShowOld_Unchecked"/>
            </Grid>

            <!-- Mật khẩu mới -->
            <TextBlock Text="Mật khẩu mới" Foreground="#555" Margin="0,0,0,4"/>
            <Grid Height="34" Margin="0,0,0,12">
                <PasswordBox x:Name="NewPassword" Padding="8,4"
                             BorderBrush="#bbb" BorderThickness="1" VerticalContentAlignment="Center"/>
                <TextBox x:Name="NewPasswordPlain" Padding="8,4"
                         BorderBrush="#bbb" BorderThickness="1" Visibility="Collapsed"
                         VerticalContentAlignment="Center"/>
                <ToggleButton x:Name="ShowNew" Content="👁" Width="30" HorizontalAlignment="Right"
                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                              Checked="ShowNew_Checked" Unchecked="ShowNew_Unchecked"/>
            </Grid>

            <!-- Xác nhận mật khẩu -->
            <TextBlock Text="Xác nhận mật khẩu mới" Foreground="#555" Margin="0,0,0,4"/>
            <Grid Height="34" Margin="0,0,0,8">
                <PasswordBox x:Name="NewPassword2" Padding="8,4"
                             BorderBrush="#bbb" BorderThickness="1" VerticalContentAlignment="Center"/>
                <TextBox x:Name="NewPassword2Plain" Padding="8,4"
                         BorderBrush="#bbb" BorderThickness="1" Visibility="Collapsed"
                         VerticalContentAlignment="Center"/>
                <ToggleButton x:Name="ShowNew2" Content="👁" Width="30" HorizontalAlignment="Right"
                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                              Checked="ShowNew2_Checked" Unchecked="ShowNew2_Unchecked"/>
            </Grid>

            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="80" Margin="0,0,8,0" Height="32" Click="Cancel_Click"/>
                <Button Content="Xác nhận" Width="110" Height="32"
                        Background="#1a237e" Foreground="White" Click="Change_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a237e"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#283593"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
