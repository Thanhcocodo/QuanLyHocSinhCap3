<Window x:Class="QuanLyHocSinh.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:QuanLyHocSinh"
        Title="Quản trị hệ thống" Height="700" Width="1150"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#c62828"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Background" Value="#1a237e"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="#1a237e">
            <DockPanel Margin="16,0">
                <TextBlock Text="🏫 Hệ thống Quản lý Học sinh" Foreground="White"
                           FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🔑 Đổi mật khẩu" Style="{StaticResource ActionBtn}"
                            Background="#283593" Foreground="White" Click="ChangePassword_Click"/>
                    <Button Content="Đăng xuất" Style="{StaticResource ActionBtn}"
                            Background="#b71c1c" Foreground="White" Click="Logout_Click"/>
                    <TextBlock x:Name="InfoText" Foreground="#bbdefb" VerticalAlignment="Center" Margin="16,0,0,0" TextAlignment="Right"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main content -->
        <TabControl Grid.Row="1" Margin="8">

            <!-- ─── Tab Thống kê ─── -->
            <TabItem Header="📊 Thống kê">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary cards -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="#e3f2fd" CornerRadius="8" Padding="20,12" Margin="0,0,12,0" MinWidth="160">
                            <StackPanel>
                                <TextBlock Text="Tổng học sinh đang học" Foreground="#555" FontSize="11"/>
                                <TextBlock x:Name="TotalStudentText" Text="..." FontSize="28" FontWeight="Bold" Foreground="#1a237e"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#e8f5e9" CornerRadius="8" Padding="20,12" Margin="0,0,12,0" MinWidth="160">
                            <StackPanel>
                                <TextBlock Text="Tổng giáo viên đang dạy" Foreground="#555" FontSize="11"/>
                                <TextBlock x:Name="TotalTeacherText" Text="..." FontSize="28" FontWeight="Bold" Foreground="#2e7d32"/>
                            </StackPanel>
                        </Border>
                        <Button Content="🔄 Tải lại thống kê" Style="{StaticResource ActionBtn}"
                                Height="Auto" Padding="16,8" Background="#1a237e" Foreground="White"
                                VerticalAlignment="Center" Click="LoadStats_Click"/>
                        <Button Content="🎓 Xử lý Lên lớp cuối năm" Style="{StaticResource ActionBtn}"
                                Height="Auto" Padding="16,8" Background="#4a148c" Foreground="White"
                                VerticalAlignment="Center" Click="OpenPromotion_Click" Margin="8,0,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── Tab Giáo viên ─── -->
            <TabItem Header="👨‍🏫 Giáo viên" Loaded="TeachersTab_Loaded">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 Tải" Style="{StaticResource ActionBtn}" Click="LoadTeachers_Click"/>
                        <Button Content="➕ Thêm GV" Style="{StaticResource PrimaryBtn}" Click="AddTeacher_Click"/>
                        <Button Content="✏️ Sửa" Style="{StaticResource ActionBtn}" Click="EditTeacher_Click"/>
                        <Button Content="🗑️ Xóa" Style="{StaticResource DangerBtn}" Click="DeleteTeacher_Click"/>
                        <Button Content="🔑 Reset MK" Style="{StaticResource ActionBtn}"
                                Background="#5c6bc0" Foreground="White" Click="ViewTeacherPassword_Click"/>
                        <Button Content="🔒 Khóa/Mở TK" Style="{StaticResource ActionBtn}"
                                Background="#37474f" Foreground="White" Click="ToggleTeacherAccount_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="TeachersGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="True" CanUserAddRows="False"
                              SelectionMode="Single" AlternatingRowBackground="#f9fbe7">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding GiaoVienId}" Width="50"/>
                            <DataGridTextColumn Header="Mã GV" Binding="{Binding MaGiaoVien}" Width="90"/>
                            <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="180"/>
                            <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="70"/>
                            <DataGridTextColumn Header="Chuyên môn" Binding="{Binding ChuyenMon}" Width="130"/>
                            <DataGridTextColumn Header="SĐT" Binding="{Binding SoDienThoai}" Width="110"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="160"/>
                            <DataGridTextColumn Header="Trạng thái" Binding="{Binding TrangThai}" Width="130"/>
                            <DataGridCheckBoxColumn Header="TK hoạt động" Binding="{Binding IsAccountActive, Mode=OneWay}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ─── Tab Lớp ─── -->
            <TabItem Header="🏫 Lớp học" Loaded="ClassesTab_Loaded">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 Tải" Style="{StaticResource ActionBtn}" Click="LoadClasses_Click"/>
                        <Button Content="➕ Thêm lớp" Style="{StaticResource PrimaryBtn}" Click="AddClass_Click"/>
                        <Button Content="🗑️ Xóa" Style="{StaticResource DangerBtn}" Click="DeleteClass_Click"/>
                        <Button Content="💾 Lưu" Style="{StaticResource ActionBtn}"
                                Background="#2e7d32" Foreground="White" Click="SaveClasses_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="ClassesGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="False" CanUserAddRows="False"
                              SelectionMode="Single" AlternatingRowBackground="#f3e5f5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding LopId}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên lớp" Binding="{Binding TenLop}" Width="120"/>
                            <DataGridTextColumn Header="Khối" Binding="{Binding Khoi}" Width="70"/>
                            <DataGridTextColumn Header="Năm học" Binding="{Binding NamHoc}" Width="110"/>
                            <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ─── Tab Môn học ─── -->
            <TabItem Header="📚 Môn học" Loaded="SubjectsTab_Loaded">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 Tải" Style="{StaticResource ActionBtn}" Click="LoadSubjects_Click"/>
                        <Button Content="➕ Thêm" Style="{StaticResource PrimaryBtn}" Click="AddSubject_Click"/>
                        <Button Content="🗑️ Xóa" Style="{StaticResource DangerBtn}" Click="DeleteSubject_Click"/>
                        <Button Content="💾 Lưu" Style="{StaticResource ActionBtn}"
                                Background="#2e7d32" Foreground="White" Click="SaveSubjects_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="SubjectsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="False" CanUserAddRows="False"
                              SelectionMode="Single" AlternatingRowBackground="#fff8e1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding MonHocId}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Mã MH" Binding="{Binding MaMh}" Width="90"/>
                            <DataGridTextColumn Header="Tên môn học" Binding="{Binding TenMh}" Width="200"/>
                            <DataGridTextColumn Header="Hệ số" Binding="{Binding HeSo}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ─── Tab Phân công ─── -->
            <TabItem Header="📋 Phân công" Loaded="AssignmentsTab_Loaded">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="🔄 Tải" Style="{StaticResource ActionBtn}" Click="LoadAssignments_Click"/>
                        <Button Content="➕ Thêm phân công" Style="{StaticResource PrimaryBtn}" Click="AddAssignment_Click"/>
                        <Button Content="🗑️ Xóa" Style="{StaticResource DangerBtn}" Click="DeleteAssignment_Click"/>
                        <Button Content="💾 Lưu" Style="{StaticResource ActionBtn}"
                                Background="#2e7d32" Foreground="White" Click="SaveAssignments_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="AssignmentsGrid" Grid.Row="1" AutoGenerateColumns="False"
                              IsReadOnly="False" CanUserAddRows="False"
                              SelectionMode="Single" AlternatingRowBackground="#e8f5e9">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding PhanCongId}" Width="50" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Lớp" Binding="{Binding TenLop}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Môn học" Binding="{Binding TenMH}" Width="150" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Giáo viên" Binding="{Binding TenGV}" Width="180" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Năm học" Binding="{Binding NamHoc}" Width="100"/>
                            <DataGridTextColumn Header="Học kỳ" Binding="{Binding HocKy}" Width="70"/>
                            <DataGridCheckBoxColumn Header="Chủ nhiệm" Binding="{Binding IsChuNhiem}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>


        </TabControl>
    </Grid>
</Window>
