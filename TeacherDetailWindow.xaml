<Window x:Class="QuanLyHocSinh.TeacherDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin Giáo viên" Height="558" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20,20,20,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleText" Text="Thêm Giáo viên" Grid.Row="0"
                   FontSize="16" FontWeight="Bold" Foreground="#1a237e" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Mã GV" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="MaGiaoVienBox" Grid.Column="1" Height="30" Padding="6,4"
                         Margin="0,0,0,8" IsReadOnly="True" Background="#f5f5f5"/>

                <TextBlock Text="Họ tên *" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="HoTenBox" Grid.Row="1" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Ngày sinh" Grid.Row="2" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <DatePicker x:Name="NgaySinhPicker" Grid.Row="2" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

                <TextBlock Text="Giới tính" Grid.Row="3" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <ComboBox x:Name="GioiTinhBox" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,0,8">
                    <ComboBoxItem Content="Nam" IsSelected="True"/>
                    <ComboBoxItem Content="Nữ"/>
                    <ComboBoxItem Content="Khác"/>
                </ComboBox>

                <TextBlock Text="Địa chỉ" Grid.Row="4" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="DiaChiBox" Grid.Row="4" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Số điện thoại" Grid.Row="5" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="SoDienThoaiBox" Grid.Row="5" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Email" Grid.Row="6" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="EmailBox" Grid.Row="6" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Chuyên môn" Grid.Row="7" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="ChuyenMonBox" Grid.Row="7" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Trình độ" Grid.Row="8" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox x:Name="TrinhDoBox" Grid.Row="8" Grid.Column="1" Height="30" Padding="6,4" Margin="0,0,0,8"/>

                <TextBlock Text="Ngày vào trường" Grid.Row="9" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <DatePicker x:Name="NgayVaoTruongPicker" Grid.Row="9" Grid.Column="1" Height="30" Margin="0,0,0,8"/>

                <TextBlock Text="Trạng thái" Grid.Row="10" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <ComboBox x:Name="TrangThaiBox" Grid.Row="10" Grid.Column="1" Height="30" Margin="0,0,0,8">
                    <ComboBoxItem Content="Đang giảng dạy" IsSelected="True"/>
                    <ComboBoxItem Content="Nghỉ phép"/>
                    <ComboBoxItem Content="Đã nghỉ việc"/>
                </ComboBox>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="ErrorText" Foreground="Red" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="Hủy" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Lưu" Width="100" Background="#1a237e" Foreground="White" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
