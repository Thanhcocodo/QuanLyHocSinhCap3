<Window x:Class="QuanLyHocSinh.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reset mật khẩu" Height="240" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Border Margin="20">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="14"
                       Foreground="#1a237e" Margin="0,0,0,12"/>

            <TextBlock Text="Mật khẩu mới" Margin="0,0,0,4"/>
            <Grid Height="34" Margin="0,0,0,8">
                <PasswordBox x:Name="NewPassword" Padding="8,4"
                             BorderBrush="#bbb" BorderThickness="1" VerticalContentAlignment="Center"/>
                <TextBox x:Name="NewPasswordPlain" Padding="8,4"
                         BorderBrush="#bbb" BorderThickness="1" Visibility="Collapsed"
                         VerticalContentAlignment="Center"/>
                <ToggleButton x:Name="ShowBtn" Content="👁" Width="30" HorizontalAlignment="Right"
                              Background="Transparent" BorderThickness="0" Cursor="Hand"
                              Checked="ShowBtn_Checked" Unchecked="ShowBtn_Unchecked"/>
            </Grid>

            <TextBlock x:Name="ErrorText" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Hủy" Width="80" Margin="0,0,8,0" Height="32" Click="Cancel_Click"/>
                <Button Content="Xác nhận" Width="100" Height="32"
                        Background="#1a237e" Foreground="White" Click="Confirm_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1a237e"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#283593"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
